<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#ff9abe"
    tools:context=".ProfileFragment">

    <!-- top and bottom border using image view -->
    <ImageView
        android:id="@+id/topBorder"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="top"
        android:scaleType="fitXY"
        android:src="@drawable/top_border"
        android:layout_marginTop="20dp"/>

    <ImageView
        android:id="@+id/bottomBorder"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_gravity="bottom"
        android:scaleType="fitXY"
        android:src="@drawable/bottom_border"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/profileTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Profile"
            android:fontFamily="@font/langar"
            android:textColor="#cb6187"
            android:textSize="35sp"
            android:textStyle="bold"
            android:layout_marginBottom="100dp"/>

        <!-- Name Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Name: "
                android:fontFamily="@font/langar"
                android:textColor="#cb6187"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginStart="50dp"
                android:layout_marginBottom="30dp"/>

            <TextView
                android:id="@+id/displayUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/langar"
                android:textColor="#000000"
                android:textSize="25sp" />
        </LinearLayout>

        <!-- Email Address Layout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="80dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Email: "
                android:fontFamily="@font/langar"
                android:textColor="#cb6187"
                android:textSize="25sp"
                android:textStyle="bold"
                android:layout_marginStart="50dp"
                android:layout_marginBottom="30dp"/>

            <TextView
                android:id="@+id/displayUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/langar"
                android:textColor="#000000"
                android:textSize="25sp" />
        </LinearLayout>

        <Button
            android:id="@+id/signOutButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Sign Out"
            android:backgroundTint="#cb6187"
            android:fontFamily="@font/langar"
            android:textSize="20sp"
            android:textStyle="bold"/>
    </LinearLayout>
</FrameLayout>

